-- Project Euler #7: 10001st Prime
-- What is the 10001st prime number?
-- Answer: 104743

(
  'n let
  n 2 lt (0) (
    -- stack: result i
    1 2
    (dup dup mul n le (over) dip and)
    (
      'ii let
      n ii mod 0 eq (drop 0) () if
      ii 1 plus
    )
    while
    drop
  ) if
) 'is-prime def

-- stack: cnt candidate
0 1
(over 10001 lt)
(
  1 plus
  dup is-prime (swap 1 plus swap) () if
)
while
nip print
