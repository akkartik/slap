-- Project Euler 7: 10001st prime number
'is-prime (
  'n let
  n 2 lt (false) (
    n iseven (n 2 eq) (
      n 1
      (2 plus dup sqr n le (over over mod 0 neq) (false) if) loop
      dup sqr n le not nip nip
    ) if
  ) if
) def

0 2
(dup is-prime (swap inc swap) () if inc over 10001 lt) loop
dec swap drop
104743 eq assert
