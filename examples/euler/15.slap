-- Project Euler #15: Lattice Paths
-- Answer: 137846528820
-- C(40,20) using DP on a 21-element row

list 21 (0 give) repeat 0 1 set box 'row let

1 'i let
(i 40 le)
(
  i 'j let
  (j 0 gt)
  (
    j 20 le (
      row ('r let r j get r j 1 sub get plus 'v let r j v set) mutate 'row let
    ) () if
    j 1 sub 'j let
  )
  while
  i 1 plus 'i let
)
while
row (20 get) lend swap free print
