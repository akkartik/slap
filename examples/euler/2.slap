-- Project Euler #2: Even Fibonacci Numbers
-- Sum of even Fibonacci numbers not exceeding 4,000,000.
-- Answer: 4613732

rec 0 'total into 1 'a into 1 'b into
(dup 'a at 4000000 le)
(
  dup 'a at 'a let
  a iseven ('total (a plus) edit) () if
  dup 'b at 'nb let
  'a (drop nb) edit 'b (a plus) edit
)
while
'total at print
