-- Project Euler #2: Even Fibonacci Numbers
-- Sum of even Fibonacci numbers not exceeding 4,000,000.
-- Answer: 4613732

rec 0 'total into 1 'a into 1 'b into
(dup 'a at must 4000000 le)
(
  dup 'a at must 'a let
  a iseven ('total (a plus) edit must) () if
  dup 'b at must 'nb let
  'a (drop nb) edit must 'b (a plus) edit must
)
while
'total at must print
