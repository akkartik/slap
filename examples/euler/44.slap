-- Project Euler #44: Pentagon Numbers
-- Find pair of pentagonal numbers whose sum and difference are pentagonal
-- Answer: 5482660

(
  'ipn-x let
  1 24 ipn-x mul plus itof fsqrt 'ipn-s let
  ipn-s ftoi 'ipn-si let
  ipn-si ipn-si mul itof ipn-s ipn-s mul sub fabs 0.5 lt (
    ipn-si 1 plus 6 mod 0 eq
  ) (0) if
) 'is-pentagonal def

-- inner-search: k -> 0 or diff (the pentagonal difference found)
(
  'is-k let
  is-k 3 is-k mul 1 sub mul 2 div 'is-pk let
  -- stack: result j
  0 1
  (dup is-k lt (over 0 eq) (0) if)
  (
    dup 3 over mul 1 sub mul 2 div 'is-pj let
    is-pk is-pj sub 'is-diff let
    is-pk is-pj plus 'is-psum let
    is-diff is-pentagonal is-psum is-pentagonal and (
      (drop is-diff) dip
    ) () if
    1 plus
  ) while
  drop
) 'inner-search def

-- stack: k
2
(dup inner-search dup 0 eq)
(drop 1 plus)
while
nip print
