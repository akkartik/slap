-- Project Euler #25: 1000-Digit Fibonacci Number
-- Index of first must Fibonacci number with 1000+ digits
-- Answer: 4782

(
  (dup len 1100 lt) (0 push) while
) 'pad-1100 let

-- add-digits: a-list a-len b-list b-len -> result-list result-len
(
  'ad-blen let 'ad-b let 'ad-alen let 'ad-a let
  ad-alen ad-blen max 'ad-n let
  (
    'adcl-j let 'adcl-carry let
    adcl-carry 0 gt (adcl-carry 10 mod push adcl-carry 10 div adcl-j 1 plus ad-carry-loop) (adcl-j) if
  ) 'ad-carry-loop let
  (
    'ad-j let 'ad-carry let
    ad-j ad-n lt (
      'ad-a ad-j nth must 'ad-b ad-j nth must plus ad-carry plus 'ad-v let
      ad-v 10 mod push
      ad-v 10 div ad-j 1 plus ad-loop
    ) (
      ad-carry ad-j ad-carry-loop
    ) if
  ) 'ad-loop let
  list 0 0 ad-loop
) 'add-digits let

-- fib-step: fa alen fb blen idx -> fa' alen' fb' blen' idx'
(
  'fs-idx let 'fs-blen let 'fs-fb let 'fs-alen let 'fs-fa let
  fs-fa fs-alen fs-fb fs-blen add-digits 'fs-clen let pad-1100 'fs-fc let
  fs-fb fs-blen fs-fc fs-clen fs-idx 1 plus
) 'fib-step let

-- stack: fa alen fb blen idx
[1] pad-1100 1 [1] pad-1100 1 2
-- predicate: check blen < 1000 (blen is 2nd from top)
(over 1000 lt)
(fib-step)
while
-- stack: fa alen fb blen idx
'final-idx let drop drop drop drop final-idx print
