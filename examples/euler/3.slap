-- Project Euler #3: Largest Prime Factor
-- Largest prime factor of 600851475143.
-- Answer: 6857

rec 600851475143 'n into 2 'i into
(dup 'i at must dup mul over 'n at must le)
(
  dup 'n at must 'n let  dup 'i at must 'i let
  n i mod 0 eq
    ('n (i div) edit must)
    ('i (1 plus) edit must)
  if
)
while
'n at must print
