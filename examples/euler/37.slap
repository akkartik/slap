-- Project Euler #37: Truncatable Primes
-- Sum of the 11 primes that are truncatable from both left and right.
-- Answer: 748317
--
-- All 11 truncatable primes are < 10^6. Sieve once, then every primality
-- check (including during left/right truncation walks) is an O(1) nth.

list 1000000 (1 push) repeat box 'sv let

sv (
  0 0 set must 1 0 set must
  2
  (dup dup mul 1000000 lt)
  (
    'i let
    i i mul
    (dup 1000000 lt)
    (dup (0 set must) dip i plus) while
    drop
    i 1 plus
  ) while
  drop
) mutate 'svb let

svb (
  'data let
  ('data swap nth must 1 eq) 'prime? def

  (
    'ltn let
    1 (dup 10 mul ltn le) (10 mul) while
    1 swap
    (dup 1 gt (over) dip and)
    (
      ltn over mod
      dup 0 eq (drop (drop 0) dip) (
        prime? not ((drop 0) dip) () if
      ) if
      10 div
    ) while
    drop
  ) 'left-trunc def

  (
    1 swap
    (dup 9 gt (over) dip and)
    (10 div dup prime? not ((drop 0) dip) () if) while
    drop
  ) 'right-trunc def

  0 0 11
  (over 11 lt)
  (
    dup prime?
    over left-trunc and
    over right-trunc and (
      dup (rot) dip plus rot rot swap inc swap
    ) () if
    2 plus
  )
  while
  drop drop
) lend
swap free print
