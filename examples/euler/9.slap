-- Project Euler #9: Special Pythagorean Triplet
-- Find a*b*c where a+b+c=1000 and a^2+b^2=c^2.
-- Answer: 31875000

'pyth? (
  -- a b -> a b bool
  over over
  over over plus 1000 swap sub
  dup sqr (swap sqr (swap sqr) dip plus) dip eq
  nip
) def

-- stack: a
1
(dup 998 lt)
(
  dup 1 plus
  -- stack: a b
  (over over plus 1000 swap sub 0 gt)
  (
    pyth?
    (
      -- stack: a b
      over over plus 1000 swap sub
      -- stack: a b c
      (mul) dip mul print halt
    ) () if
    1 plus
  )
  while
  drop
  1 plus
)
while
drop
