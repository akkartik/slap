-- Project Euler 16: Sum of the digits of 2^1000
-- Base-10^9 representation, double 1000 times
1000000000 'B let

'digit-sum (
  0 swap
  (dup 0 gt) (dup 10 imod rot iplus swap 10 idiv) while
  drop
) def

0 35 range (drop 0) map 0 1 put
(
  0 0
  (dup 35 lt) (
    'i let 'c let
    dup i -1 at 2 imul c iplus
    dup B imod 'd let B idiv 'c2 let
    i d put c2 i inc
  ) while
  drop drop
) 1000 repeat
(digit-sum) map sum
1366 eq assert
