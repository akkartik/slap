-- division by zero
10 0 idiv
10 0 imod
10.0 0.0 fdiv
-- slice put out of bounds
[1 2 3] 5 99 put
[1 2 3] -1 99 put
-- list-assign out of bounds
[1 2 3] list 5 99 list-assign free
-- str-assign out of bounds
"abc" str 5 122 str-assign free
-- record get missing key
(('a 1)) rec 'z get
-- assertion failure
false assert
-- stack underflow
drop
-- car empty tuple
() car
-- lt on Symbol (not supported)
'a 'b lt
-- (map/filter/each on non-slice caught by type checker, see type-err.slap)
-- dice element not a tuple
[1 2 3] dice
-- rec element not a tuple
(1 2 3) rec
-- select out of bounds
[1 2 3] [5] select
-- keep-mask length mismatch
[1 2 3] [true false] keep-mask
-- windows size must be positive
[1 2 3] 0 windows
-- reshape: not divisible
[1 2 3 4 5] 2 reshape
-- reshape: cols must be positive
[1 2 3] 0 reshape
-- transpose: ragged array
[[1 2] [3 4 5]] transpose
-- group: length mismatch
[1 2 3] [0 1] group
-- partition: length mismatch
[1 2 3] [1 1] partition
