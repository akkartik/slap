-- dup on linear Box
42 box dup free free
-- dup on linear List
[1] list dup free free
-- dup on linear Dict
[("a" 1)] dice dict dup free free
-- dup on linear String
"hi" str dup free free
-- unknown word at top level
qwerty
-- drop on linear Box
42 box drop
-- drop on linear List
[1] list drop
-- drop on linear Dict
[("a" 1)] dice dict drop
-- drop on linear String
"hi" str drop
-- type mismatch: iplus on float
1.0 2.0 iplus
-- type mismatch: fplus on int
1 2 fplus
-- apply non-tuple
42 apply
-- type mismatch in eq
1 'a eq
-- get on non-record
42 'a get
-- grab on non-dice
42 "a" -1 grab
-- expected Int for iplus
'a 1 iplus
-- if with non-int condition
'a (1) (2) if
-- loop body must return Int
('a) loop
-- map on non-slice
42 (inc) map
-- filter on non-slice
42 (iszero) filter
-- each on non-slice
42 (drop) each
-- fsub on int
1 2 fsub
-- fdiv on int
1 2 fdiv
-- ftoi on int
42 ftoi
-- itof on float
3.14 itof
-- assert on non-int
'a assert
-- not on non-int
'a not
-- and on non-int
'a 1 and
-- or on non-int
'a 1 or
-- box inner then iplus (box is not Int)
42 box 1 iplus
-- list-concat expects slice
[1] list 42 list-concat free
-- str expects slice of int
42 str
-- fsqrt on int
42 fsqrt
-- fsin on int
42 fsin
-- fpow on int
2 3 fpow
-- scan on non-slice
42 0 (iplus) scan
-- where on non-int-slice
['a 'b 'c] where
-- select on non-slice
42 [0] select
-- table on non-slice
42 [1] (iplus) table
-- recur with non-symbol
42 recur
-- dup on slice of linear (Box)
[1 box] dup
-- lend body gets wrong snapshot type (List lends Slice, not Int)
[1 2 3] list (1 iplus) lend swap free
-- dedup on slice of linear (Box)
[1 box 2 box] dedup
-- member on slice of linear (Box)
[1 box] [2 box] member
-- index-of on slice of linear (Box)
1 box [2 box] index-of
-- dup on record containing linear Box
{'a 10 box} dup
-- let binding of linear value
10 box 'x let x free
-- let binding used twice (linear)
10 box 'x let x x free free
-- clone on non-linear
42 clone
-- free on non-linear
42 free
-- lend on non-linear
42 () lend
-- get field type mismatch (Symbol used as Int)
{'a 5 'b 'x} 'b get 1 iplus
-- get missing field on closed record
{'a 5} 'z get
-- set type mismatch (Symbol where Int expected)
{'a 5} 'x 'a set
-- match branch effect mismatch
'b {'a (1) 'b (2 3)} (0) match
-- cond body effect mismatch
5 [((3 lt) (drop 'small 'extra))] (drop 'big) cond
-- polymorphic dup smuggles linear through generics
'mydup (dup) def 42 box mydup
-- polymorphic clone on non-linear
'myclone (clone) def 42 myclone
-- def of linear value (aliasing)
'x 42 box def
