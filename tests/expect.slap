10 bits [1 0 1 0] eq assert
0 bits [0] eq assert
1 bits [1] eq assert

-- ═══ Array Primitives: rise / fall ═══

-- rise (argsort ascending)
[30 10 20] rise [1 2 0] eq assert free
[1 2 3] rise [0 1 2] eq assert free
[] rise [] eq assert free

-- fall (argsort descending)
[30 10 20] fall [0 2 1] eq assert free
[1 2 3] fall [2 1 0] eq assert free

-- rise + select = sort
[30 10 20] rise select [10 20 30] eq assert

-- ═══ Array Primitives: classify ═══

[1 2 3 1 2 1] classify [0 1 2 0 1 0] eq assert free
[5 5 5] classify [0 0 0] eq assert free
[1 2 3] classify [0 1 2] eq assert free
[] classify [] eq assert free

-- ═══ Array Primitives: occurrences ═══

[1 2 3 1 2 1] occurrences [0 0 0 1 1 2] eq assert free
[5 5 5] occurrences [0 1 2] eq assert free
[1 2 3] occurrences [0 0 0] eq assert free
[] occurrences [] eq assert free

-- ═══ Array Primitives: replicate ═══

[10 20 30] [1 0 2] replicate [10 30 30] eq assert
[10 20 30] [0 0 0] replicate [] eq assert
[10 20 30] [1 1 1] replicate [10 20 30] eq assert
[] [] replicate [] eq assert

-- ═══ Array Primitives: find ═══

[1 2 3 4 2 3] [2 3] find [false true false false true false] eq assert free
[1 2 3] [9] find [false false false] eq assert free
[1 2 3] [] find [true true true] eq assert free

-- ═══ Array Primitives: reshape ═══

[1 2 3] 5 reshape [1 2 3 1 2] eq assert
[1 2 3] 3 reshape [1 2 3] eq assert
[1 2 3] 1 reshape [1] eq assert
[1 2 3] 0 reshape [] eq assert

-- ═══ Array Primitives: base ═══

10 2 base [1 0 1 0] eq assert
255 16 base [15 15] eq assert
0 2 base [0] eq assert
7 10 base [7] eq assert
100 10 base [1 0 0] eq assert

-- ═══ Array Primitives: transpose ═══

[[1 2 3] [4 5 6]] transpose [[1 4] [2 5] [3 6]] eq assert
[[1 2] [3 4] [5 6]] transpose [[1 3 5] [2 4 6]] eq assert
[[1] [2] [3]] transpose [[1 2 3]] eq assert
[] transpose [] eq assert

-- ═══ Argument Combinators ═══

-- self: x (f) → f(x,x)
3 (mul) self 9 eq assert
5 (plus) self 10 eq assert

-- backward: x y (f) → f(y,x)
3 10 (sub) backward 7 eq assert
2 8 (sub) apply -6 eq assert
2 8 (sub) backward 6 eq assert

-- gap: x y (f) → f(y)
99 5 (inc) gap 6 eq assert

-- on: x (f) → x f(x)
5 (inc) on 6 eq assert 5 eq assert

-- bracket: x y (f) (g) → f(x) g(y)
3 10 (inc) (dec) bracket 9 eq assert 4 eq assert

-- ═══ Composition: New Ops ═══

-- distance via sqrt
3.0 4.0 (dup fmul) both fadd sqrt 5.0 eq assert

-- angle via atan2
1.0 1.0 atan2 pi 4.0 fdiv fsub fabs 0.001 flt assert

-- argsort then select
[30 10 50 20 40] rise select [10 20 30 40 50] eq assert

-- classify + occurrences combo
'hello [104 101 108 108 111] classify [0 1 2 2 3] eq assert free

-- ═══ Math: pow / log / trig ═══

-- pow
2.0 10.0 pow 1024.0 eq assert
3.0 2.0 pow 9.0 eq assert
4.0 0.5 pow 2.0 eq assert

-- log / exp round-trip
1.0 exp log 1.0 fsub fabs 0.0001 flt assert
2.718281828 log 1.0 fsub fabs 0.001 flt assert

-- tan
0.0 tan 0.0 eq assert

-- asin / acos
0.0 asin 0.0 eq assert
1.0 acos 0.0 eq assert

-- ═══ Float Comparisons ═══

-- fgt
5.0 3.0 fgt assert
3.0 5.0 fgt not assert
3.0 3.0 fgt not assert

-- fge
5.0 3.0 fge assert
3.0 3.0 fge assert
2.0 3.0 fge not assert

-- fle
3.0 5.0 fle assert
3.0 3.0 fle assert
5.0 3.0 fle not assert

-- feq / fneq
3.14 3.14 feq assert
3.14 2.71 feq not assert
3.14 2.71 fneq assert
3.14 3.14 fneq not assert

-- fmin / fmax
3.0 7.0 fmin 3.0 eq assert
3.0 7.0 fmax 7.0 eq assert
-1.0 1.0 fmin -1.0 eq assert
-1.0 1.0 fmax 1.0 eq assert

-- ═══ Float Prelude ═══

-- fclamp
15.0 0.0 10.0 fclamp 10.0 eq assert
-5.0 0.0 10.0 fclamp 0.0 eq assert
5.0 0.0 10.0 fclamp 5.0 eq assert

-- fbetween?
5.0 0.0 10.0 fbetween? assert
-1.0 0.0 10.0 fbetween? not assert
11.0 0.0 10.0 fbetween? not assert

-- fsign
5.0 fsign 1.0 eq assert
-3.0 fsign -1.0 eq assert
0.0 fsign 0.0 eq assert

-- degrees / radians
pi degrees 180.0 fsub fabs 0.001 flt assert
180.0 radians pi fsub fabs 0.001 flt assert

-- hypot
3.0 4.0 hypot 5.0 eq assert
5.0 12.0 hypot 13.0 eq assert

-- ═══ Higher-Order Array Ops ═══

-- group
[0 1 0 1 0] [10 20 30 40 50] (sum) group [90 60] eq assert
[0 1 2 0] [1 2 3 4] (len swap free) group [2 1 1] eq assert

-- partition
[1 1 0 2 2] [10 20 30 40 50] (sum) partition [30 90] eq assert
[1 1 1] [5 6 7] (sum) partition [18] eq assert

-- reduce
[1 2 3 4 5] (plus) reduce 15 eq assert
[3 1 4 1 5] (max) reduce 5 eq assert
[7] (plus) reduce 7 eq assert

-- ═══ Composition: New Ops ═══

-- pow for integer exponent via itof
2 itof 8 itof pow ftoi 256 eq assert

-- sort by custom key (argsort pattern)
[30 10 50 20 40] fall select [50 40 30 20 10] eq assert

-- reduce vs fold equivalence
[1 2 3 4 5] (plus) reduce [1 2 3 4 5] 0 (plus) fold eq assert

-- ═══ Quotation Push/Pop ═══

-- pop: extract last literal
(1 2 3) pop 3 eq assert apply 2 eq assert 1 eq assert

-- pop: multiple pops
(1 2 3) pop 3 eq assert pop 2 eq assert pop 1 eq assert apply

-- pop: extract nested quotation
((1 2) (3 4)) pop apply 4 eq assert 3 eq assert pop apply 2 eq assert 1 eq assert apply

-- pop: from quote-created (captured) quotation
42 quote pop 42 eq assert apply

-- push: add value to quotation
(1 2) 3 push apply 3 eq assert 2 eq assert 1 eq assert

-- push: chained pushes (tests compose fix)
() 1 push 2 push 3 push apply 3 eq assert 2 eq assert 1 eq assert

-- pop after push roundtrip
(1) 2 push pop 2 eq assert pop 1 eq assert apply

-- quotation as tuple: extract pair
((10 plus) (20 plus)) pop swap pop swap apply
-- stack: (20 plus) (10 plus) — top is first-pushed
5 swap apply 15 eq assert
5 swap apply 25 eq assert

-- ═══ Cond ═══

-- cond: basic match on second predicate
2 [((1 eq) (drop 'one)) ((2 eq) (drop 'two)) ((3 eq) (drop 'three))] (drop 'other) cond 'two eq assert

-- cond: falls through to default
99 [((1 eq) (drop 'one))] (drop 'other) cond 'other eq assert

-- cond: first match wins
1 [((1 eq) (drop 'one)) ((1 eq) (drop 'also-one))] (drop 'default) cond 'one eq assert

-- cond: empty clauses
42 [] (drop 'default) cond 'default eq assert

-- cond: scrutinee passed to body
10 [((5 lt) (2 mul)) ((20 lt) (3 mul))] (drop 0) cond 30 eq assert
