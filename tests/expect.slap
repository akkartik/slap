-- ═══ Adversarial: Recursion ═══

-- fibonacci
'fib (dup 2 lt
  ()
  (dup 1 sub fib swap 2 sub fib plus)
  choose
) def
0 fib 0 eq assert
1 fib 1 eq assert
6 fib 8 eq assert
10 fib 55 eq assert

-- factorial
'fact (dup 0 eq (drop 1) (dup 1 sub fact mul) choose) def
0 fact 1 eq assert
5 fact 120 eq assert
10 fact 3628800 eq assert

-- GCD
'gcd (dup 0 eq
  (drop)
  (swap over divmod nip gcd)
  choose
) def
48 18 gcd 6 eq assert
100 75 gcd 25 eq assert
17 13 gcd 1 eq assert

-- countdown to array
'countdown (dup 0 eq
  (drop [])
  (dup 1 sub countdown cons)
  choose
) def
5 countdown [5 4 3 2 1] eq assert
0 countdown [] eq assert

