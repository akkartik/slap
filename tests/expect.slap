-- ── Int math ──
1 2 iplus 3 eq assert
10 3 isub 7 eq assert
3 4 imul 12 eq assert
10 3 idiv 3 eq assert
10 3 imod 1 eq assert

-- ── Polymorphic math ──
1 2 plus 3 eq assert
10 3 sub 7 eq assert
3 4 mul 12 eq assert
10 3 div 3 eq assert
10 3 mod 1 eq assert
1.0 2.0 plus 3.0 eq assert
10.0 3.0 sub 7.0 eq assert
2.0 3.0 mul 6.0 eq assert
10.0 4.0 div 2.5 eq assert

-- ── Float math ──
1.0 2.0 fplus 3.0 eq assert
10.0 3.0 fsub 7.0 eq assert
2.0 3.0 fmul 6.0 eq assert
10.0 4.0 fdiv 2.5 eq assert

-- ── Conversion ──
42 itof 42.0 eq assert
3.9 ftoi 3 eq assert

-- ── Booleans ──
true not false eq assert
false not true eq assert
true true and true eq assert
true false and false eq assert
false true or true eq assert
false false or false eq assert

-- ── Comparison ──
1 2 lt assert
2 1 lt not assert
1 1 eq assert
1 2 eq not assert
'a 'a eq assert
'a 'b eq not assert
true true eq assert
true false eq not assert
1.0 2.0 lt assert

-- ── Stack ops ──
1 dup iplus 2 eq assert
1 2 swap 1 eq assert drop
1 2 () dip 2 eq assert 1 eq assert

-- ── Control: apply ──
(42) apply 42 eq assert
1 2 (iplus) apply 3 eq assert

-- ── Control: if ──
true (1) (2) if 1 eq assert
false (1) (2) if 2 eq assert

-- ── Control: loop ──
0 (1 iplus dup 10 lt) loop 10 eq assert

-- ── Control: match ──
'a {'a (1) 'b (2)} (0) match 1 eq assert
'b {'a (1) 'b (2)} (0) match 2 eq assert
'c {'a (1) 'b (2)} (0) match 0 eq assert

-- ── Tuples: compose ──
(1) (2) compose apply 2 eq assert drop
(1 2) (iplus) compose apply 3 eq assert

-- ── Tuples: cons ──
() 42 cons apply 42 eq assert
(1) 2 cons apply 2 eq assert drop

-- ── Tuples: car ──
(42) car 42 eq assert drop
(1 2) car 2 eq assert drop

-- ── Slices ──
[] len 0 eq assert
[1 2 3] len 3 eq assert
[1 2 3] 0 -1 at 1 eq assert
[1 2 3] 1 -1 at 2 eq assert
[1 2 3] 2 -1 at 3 eq assert
[1 2 3] 5 -1 at -1 eq assert
[1 2 3] -1 -1 at -1 eq assert
